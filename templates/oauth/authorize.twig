{% extends 'layout.twig' %}

{% block title %}Authorize Application{% endblock %}

{% block head %}
  <link rel="stylesheet" href="{{ basePath }}/css/main.css">
  <link rel="stylesheet" href="{{ basePath }}/css/dark.css" media="all">
{% endblock %}

{% block body_class %}uk-padding{% endblock %}

{% block body %}
  {% embed 'topbar.twig' %}{% endembed %}
<div class="uk-container uk-flex uk-flex-center uk-margin-large-top">
  <div class="uk-width-1-1@s uk-width-1-2@m uk-width-1-3@l">
    <div class="uk-width-1-1 uk-margin-auto uk-card qr-card uk-card-body uk-box-shadow-large">
      <h3 class="uk-card-title uk-text-center">Application Authorization</h3>

      <p class="uk-text-center">
        <strong>{{ client.name|default('Unknown Application') }}</strong> requests access to your namespace <code>{{ client.namespace }}</code>.
      </p>

      <div class="uk-margin">
        <h4>Requested permissions:</h4>
        <ul class="uk-list uk-list-divider">
          {% for detail in scopeDetails %}
            <li>
              <div>
                <strong>{{ detail.label }}</strong>
                <code class="uk-text-small uk-margin-small-left">{{ detail.scope }}</code>
              </div>
              {% if detail.description %}
                <div class="uk-text-muted uk-text-small">{{ detail.description }}</div>
              {% endif %}
              {% if detail.tools is not empty %}
                <div class="uk-text-small uk-margin-small-top">
                  <span class="uk-text-muted">MCP tools:</span>
                  {% for tool in detail.tools %}
                    <code class="uk-text-small">{{ tool }}</code>{% if not loop.last %}, {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>

      <form method="post" action="{{ basePath }}/oauth/authorize">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="client_id" value="{{ client.id }}">
        <input type="hidden" name="redirect_uri" value="{{ redirect_uri }}">
        <input type="hidden" name="scope" value="{{ scopes|join(' ') }}">
        <input type="hidden" name="state" value="{{ state }}">
        <input type="hidden" name="code_challenge" value="{{ code_challenge }}">

        <div class="uk-margin uk-flex uk-flex-between">
          <button type="submit" name="deny" class="uk-button uk-button-default uk-width-1-2 uk-margin-small-right">Deny</button>
          <button type="submit" name="approve" class="uk-button uk-button-primary uk-width-1-2">Approve</button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
