{% extends 'layouts/cms_base.twig' %}

{% set normalizedNamespace = designNamespace|default('default') %}
{% set pageTitle = metaTitle|default('') %}
{% set incomingDesign = design|default(renderContext.design|default({})) %}
{% set effectiveAppearance = incomingDesign.appearance|default(appearance|default(renderContext.design.appearance|default({}))) %}
{% set design = incomingDesign|merge({
  theme: pageTheme|default(incomingDesign.theme|default('light')),
  appearance: effectiveAppearance
}) %}
{% set headerTheme = pageTheme|default(design.theme|default('light')) %}

{% set menuItems = menu|default([]) %}
{% set cmsMenuItems = menuItems|default([]) %}
{% set includeCmsBaseStyles = false %}
{% set includeLegacyMarketingStyles = false %}
{% set includeUikitStyles = true %}
{% set includeMainStyles = false %}
{% set includeVariablesStyles = true %}
{% set includeTableStyles = false %}
{% set includeTopbarStyles = false %}
{% set includeMarketingTopbarStyles = false %}
{% set includeNamespaceTokensStyles = true %}
{% set logoSettings = headerLogo|default({}) %}
{% set logoMode = logoSettings.mode|default('text') %}
{% set logoSrc = logoSettings.src|default(null) %}
{% set logoLabel = logoSettings.label|default(pageTitle|default('edocs')) %}
{% set logoAlt = logoSettings.alt|default(logoLabel) %}
{% set cmsChatEnabled = (cmsChatEndpoint is defined and cmsChatEndpoint) or (featureFlags.chatEndpoint|default(false) == true) %}
{% set cookieConsent = cookieConsentConfig|default({}) %}
{% set cookieConsentEnabled = cookieConsent.enabled|default(false) %}

{% block body_theme %}
  {{ pageTheme|default('light') }}
{% endblock %}

{% block title %}{{ pageTitle|default('edocs') }}{% endblock %}

{% block body_class %}page-render cms-page-render marketing-page uk-background-default{% endblock %}

{% block head %}
  {#
    Marketing pages avoid global UI bundles by default (see includeMainStyles).
    dark.css and highcontrast.css are loaded explicitly here because
    includeCmsBaseStyles=false prevents them from loading via cms_base.

    Non-critical CSS is loaded async via the media="print" pattern to avoid
    render-blocking (~540KB). The onload handler switches to media="all"
    once downloaded. <noscript> fallbacks ensure styles load without JS.
  #}
  {{ parent() }}
  <link rel="stylesheet" href="{{ basePath }}/css/dark.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ basePath }}/css/dark.css" media="all"></noscript>
  <link rel="stylesheet" href="{{ basePath }}/css/highcontrast.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ basePath }}/css/highcontrast.css"></noscript>
  <link rel="stylesheet" href="{{ basePath }}/css/sections.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ basePath }}/css/sections.css"></noscript>
  <link rel="preload" href="{{ basePath }}/css/marketing.css" as="style">
  <link rel="stylesheet" href="{{ basePath }}/css/marketing.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ basePath }}/css/marketing.css"></noscript>
  <link rel="stylesheet" href="{{ basePath }}/css/marketing-cards.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ basePath }}/css/marketing-cards.css"></noscript>
  <link rel="stylesheet" href="{{ basePath }}/css/topbar.marketing.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ basePath }}/css/topbar.marketing.css"></noscript>
  <script type="module" src="{{ basePath }}/js/marketing-design.js" defer></script>
{% endblock %}

{% block site_header %}
  {% include 'pages/partials/header.twig' with {
    normalizedNamespace: normalizedNamespace,
    headerTheme: headerTheme,
    headerLogo: logoSettings,
    cmsMenuItems: cmsMenuItems,
    cmsMainNavigation: cmsMainNavigation|default([]),
    headerConfig: headerConfig|default({}),
    basePath: basePath,
    cmsSlug: cmsSlug,
    pageTitle: pageTitle
  } only %}
{% endblock %}

{% block body %}
  {% include 'marketing/partials/design-data.twig' %}

  {% if embeddedPayload is defined and embeddedPayload %}
  <script data-json="page" type="application/json">
    {{ embeddedPayload|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES'))|raw }}
  </script>
  {% endif %}

  <div
    class="cms-page"
    data-page-root
    data-page-slug="{{ cmsSlug }}"
    data-page-namespace="{{ designNamespace }}"
    data-content-namespace="{{ contentNamespace }}"
  >
    {{ content|raw }}
  </div>

  <noscript>
    {{ content|raw }}
  </noscript>

  {% if checkoutApp is defined and checkoutApp and subscriptionPlans is defined and subscriptionPlans|length > 0 %}
    {# Auth-gated checkout: plan cards link to /stripe/checkout?plan=X&app=Y #}
    <section class="uk-section page-module-pricing-table">
      <div class="uk-container">
        <div class="uk-grid uk-grid-match uk-child-width-1-3@m uk-child-width-1-1" uk-grid>
          {% for plan in subscriptionPlans %}
            <div>
              <div class="uk-card uk-card-default uk-card-body uk-text-center{% if plan.highlighted|default(false) %} uk-card-primary{% endif %}">
                <h3 class="uk-card-title">{{ plan.name }}</h3>
                {% if plan.price_label is defined and plan.price_label %}
                  <div class="uk-text-lead uk-margin-small-bottom">{{ plan.price_label }}</div>
                {% endif %}
                {% if plan.features|default([])|length > 0 %}
                  <ul class="uk-list uk-list-bullet uk-text-left">
                    {% for feature in plan.features %}
                      <li>{{ feature }}</li>
                    {% endfor %}
                  </ul>
                {% endif %}
                {% if plan.trial_days|default(0) > 0 %}
                  <p class="uk-text-muted uk-text-small">{{ plan.trial_days }} Tage kostenlos testen</p>
                {% endif %}
                <a href="{{ basePath }}/stripe/checkout?plan={{ plan.plan_key|url_encode }}&app={{ checkoutApp|url_encode }}"
                   class="uk-button uk-button-primary uk-button-large uk-width-1-1 uk-margin-small-top">
                  Jetzt starten
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% elseif pricingTableId is defined and pricingTableId and stripePublishableKey is defined and stripePublishableKey %}
    {# Fallback: embedded Stripe Pricing Table #}
    <section class="uk-section page-module-pricing-table">
      <div class="uk-container">
        <stripe-pricing-table
          pricing-table-id="{{ pricingTableId|e('html_attr') }}"
          publishable-key="{{ stripePublishableKey|e('html_attr') }}"
          client-reference-id="{{ contentNamespace|default(designNamespace|default(''))|e('html_attr') }}"
        ></stripe-pricing-table>
      </div>
    </section>
    <script async src="https://js.stripe.com/v3/pricing-table.js"></script>
  {% endif %}

  {% if cmsChatEnabled %}
    {% include 'marketing/partials/marketing-chat.twig' %}
  {% endif %}
  {% if cookieConsentEnabled %}
    {% include 'marketing/partials/cookie-consent.twig' with {
      privacyUrl: privacyUrl,
      cookieConsentConfig: cookieConsent
    } %}
  {% endif %}
{% endblock %}

{% block scripts %}
  {% if cmsChatEnabled %}
    <script>
      window.marketingChatConfig = {
        endpoint: '{{ cmsChatEndpoint|default('')|e('js') }}',
        slug: '{{ cmsSlug|e('js') }}',
        csrfToken: '{{ csrf_token|default('')|e('js') }}',
        locale: '{{ locale() }}',
        texts: {
          intro: '{{ t('marketing_chat_intro_message')|e('js') }}',
          loading: '{{ t('marketing_chat_loading')|e('js') }}',
          errorGeneric: '{{ t('marketing_chat_error_generic')|e('js') }}',
          errorValidation: '{{ t('marketing_chat_error_validation')|e('js') }}',
          errorRateLimited: '{{ t('marketing_chat_error_rate_limited')|e('js') }}',
          sources: '{{ t('marketing_chat_sources')|e('js') }}',
          sourcesToggle: '{{ t('marketing_chat_sources_toggle')|e('js') }}',
          score: '{{ t('marketing_chat_score')|e('js') }}',
          empty: '{{ t('marketing_chat_empty')|e('js') }}',
          question: '{{ t('marketing_chat_question_label')|e('js') }}'
        }
      };
    </script>
    <script src="{{ basePath }}/js/marketing-chat.js" defer></script>
  {% endif %}
  {% if cookieConsentEnabled %}
    <script>
      window.cookieConsentConfig = {{ cookieConsent|json_encode|raw }};
    </script>
    <script src="{{ basePath }}/js/marketing-cookie.js" defer></script>
    <script src="{{ basePath }}/js/marketing-consent.js" defer></script>
  {% endif %}
{% endblock %}
