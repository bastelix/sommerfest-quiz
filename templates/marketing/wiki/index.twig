{% extends 'layout.twig' %}

{% set themeDefaults = {
  'bodyClasses': ['marketing-wiki'],
  'stylesheets': [],
  'colors': {}
} %}
{% set bodyClasses = themeDefaults.bodyClasses %}
{% set stylesheets = themeDefaults.stylesheets %}
{% set themeColors = {} %}
{% set logoUrl = wikiTheme.logoUrl|default(null) %}
{% if wikiTheme is defined %}
  {% if wikiTheme.bodyClasses is defined and wikiTheme.bodyClasses is iterable %}
    {% set bodyClasses = wikiTheme.bodyClasses %}
  {% endif %}
  {% if wikiTheme.stylesheets is defined and wikiTheme.stylesheets is iterable %}
    {% set stylesheets = wikiTheme.stylesheets %}
  {% endif %}
  {% if wikiTheme.colors is defined %}
    {% set themeColors = wikiTheme.colors %}
  {% endif %}
  {% if wikiTheme.logoUrl is defined %}
    {% set logoUrl = wikiTheme.logoUrl %}
  {% endif %}
{% endif %}

{% block title %}{{ menuLabel }} – {{ page.getTitle() }}{% endblock %}

{% block body_class %}marketing-page {{ (bodyClasses is not empty ? bodyClasses : ['marketing-wiki'])|join(' ') }}{% endblock %}

{% block site_header %}
  {% if cmsMainNavigation is defined and cmsMainNavigation is not empty %}
    {% include 'pages/partials/header.twig' with {
      normalizedNamespace: designNamespace|default('default'),
      headerTheme: 'light',
      headerLogo: headerLogo|default({}),
      cmsMenuItems: [],
      cmsMainNavigation: cmsMainNavigation|default([]),
      headerConfig: headerConfig|default({}),
      basePath: basePath,
      cmsSlug: cmsSlug|default(''),
      pageTitle: pageTitle|default('QuizRace')
    } only %}
  {% endif %}
{% endblock %}

{% block head %}
  <link rel="preload" href="{{ basePath }}/css/marketing.css" as="style">
  <link rel="stylesheet" href="{{ basePath }}/css/marketing.css">
  <link rel="stylesheet" href="{{ basePath }}/css/highcontrast.css">
  <link rel="stylesheet" href="{{ basePath }}/css/topbar.marketing.css">
  <script type="module" src="{{ basePath }}/js/marketing-design.js"></script>
  {% for stylesheet in stylesheets %}
    {% set href = stylesheet matches '/^https?:\\/\\//i' or stylesheet starts with('//') ? stylesheet : (stylesheet starts with('/') ? stylesheet : basePath ~ '/css/' ~ stylesheet) %}
    <link rel="stylesheet" href="{{ href }}">
  {% endfor %}
  {% include 'marketing/partials/theme-vars.twig' with {
    appearance: appearance|default({}),
    design: design|default({}),
    normalizedNamespace: designNamespace|default('default')
  } only %}
  <style>
    /* ── Notion-inspired wiki layout ── */
    .wiki-layout {
      display: grid;
      grid-template-columns: 280px 1fr;
      min-height: calc(100vh - 120px);
      background: var(--marketing-background, var(--surface-page, #f7f9fb));
    }

    @media (max-width: 959px) {
      .wiki-layout {
        grid-template-columns: 1fr;
      }
    }

    /* ── Sidebar ── */
    .wiki-sidebar {
      background: var(--marketing-surface-muted, var(--surface-muted, #eef2f7));
      border-right: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
      padding: 24px 16px;
      overflow-y: auto;
      position: sticky;
      top: 0;
      height: 100vh;
    }

    @media (max-width: 959px) {
      .wiki-sidebar {
        position: static;
        height: auto;
        border-right: none;
        border-bottom: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
        padding: 16px;
      }
    }

    .wiki-sidebar__title {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #4b5563));
      padding: 0 8px;
      margin: 0 0 8px;
    }

    .wiki-sidebar__search {
      position: relative;
      margin-bottom: 16px;
    }

    .wiki-sidebar__search-input {
      width: 100%;
      padding: 8px 12px 8px 36px;
      border: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
      border-radius: 6px;
      background: var(--marketing-surface, var(--surface-card, #ffffff));
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
      box-sizing: border-box;
    }

    .wiki-sidebar__search-input:focus {
      border-color: var(--marketing-primary, var(--brand-primary, #1e87f0));
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--marketing-primary, var(--brand-primary, #1e87f0)) 12%, transparent);
    }

    .wiki-sidebar__search-input::placeholder {
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #6b7280));
    }

    .wiki-sidebar__search-icon {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #9ca3af));
      pointer-events: none;
      width: 16px;
      height: 16px;
    }

    .wiki-sidebar__nav {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .wiki-sidebar__nav-item {
      margin: 0;
    }

    .wiki-sidebar__nav-link {
      display: block;
      padding: 6px 8px;
      border-radius: 6px;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      font-size: 0.875rem;
      line-height: 1.4;
      text-decoration: none;
      transition: background 0.12s ease;
    }

    .wiki-sidebar__nav-link:hover {
      background: color-mix(in srgb, var(--marketing-primary, var(--brand-primary, #1e87f0)) 8%, transparent);
      text-decoration: none;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
    }

    .wiki-sidebar__nav-date {
      display: block;
      font-size: 0.7rem;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #9ca3af));
      margin-top: 2px;
    }

    /* ── Main content area ── */
    .wiki-main {
      padding: 40px 48px;
      max-width: 900px;
    }

    @media (max-width: 959px) {
      .wiki-main {
        padding: 24px 16px;
      }
    }

    .wiki-main__breadcrumb {
      margin-bottom: 24px;
    }

    .wiki-main__breadcrumb .uk-breadcrumb > li:nth-child(n+2)::before {
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #9ca3af));
    }

    .wiki-main__breadcrumb .uk-breadcrumb > li > a {
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #6b7280));
      font-size: 0.875rem;
    }

    .wiki-main__breadcrumb .uk-breadcrumb > li.uk-active > span {
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      font-size: 0.875rem;
    }

    .wiki-main__header {
      margin-bottom: 32px;
    }

    .wiki-main__title {
      font-size: clamp(1.75rem, 3vw, 2.25rem);
      font-weight: 700;
      color: var(--marketing-text-on-surface, var(--text-heading, #0b1728));
      margin: 0 0 8px;
      line-height: 1.2;
    }

    .wiki-main__subtitle {
      font-size: 1rem;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #4b5563));
      margin: 0;
      line-height: 1.5;
    }

    .wiki-main__logo {
      margin-bottom: 16px;
    }

    .wiki-main__logo img {
      max-height: 48px;
      width: auto;
    }

    /* ── Article rows (Notion-style database view) ── */
    .wiki-articles {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .wiki-article-row {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 16px;
      padding: 12px 16px;
      border-radius: 6px;
      text-decoration: none;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      transition: background 0.12s ease;
    }

    .wiki-article-row:hover {
      background: var(--marketing-surface-muted, var(--surface-muted, #f1f5f9));
      text-decoration: none;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
    }

    .wiki-article-row__title {
      font-size: 0.9375rem;
      font-weight: 500;
      margin: 0;
      line-height: 1.3;
    }

    .wiki-article-row__excerpt {
      font-size: 0.8125rem;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #6b7280));
      margin: 2px 0 0;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .wiki-article-row__date {
      font-size: 0.75rem;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #9ca3af));
      white-space: nowrap;
    }

    /* ── Empty state ── */
    .wiki-empty {
      text-align: center;
      padding: 48px 16px;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #6b7280));
    }
  </style>
{% endblock %}

{% block body %}
  {% include 'marketing/partials/design-data.twig' %}
  <div class="wiki-layout">
    {# ── Sidebar ── #}
    <aside class="wiki-sidebar" id="wikiSidebar">
      {% if logoUrl %}
        <div class="wiki-main__logo uk-margin-small">
          <img src="{{ logoUrl }}" alt="{{ page.getTitle() }} Logo" loading="lazy">
        </div>
      {% endif %}
      <p class="wiki-sidebar__title">{{ menuLabel }}</p>
      <form method="get" class="wiki-sidebar__search">
        <svg class="wiki-sidebar__search-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/>
        </svg>
        <label class="uk-hidden" for="wiki-search">Suche</label>
        <input id="wiki-search"
               name="q"
               class="wiki-sidebar__search-input"
               type="search"
               placeholder="Suchen..."
               value="{{ searchTerm }}">
      </form>
      <ul class="wiki-sidebar__nav">
        {% for article in articles %}
          <li class="wiki-sidebar__nav-item">
            <a class="wiki-sidebar__nav-link"
               href="{{ wikiBasePath }}/{{ article.getSlug() }}">
              {{ article.getTitle() }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </aside>

    {# ── Main content ── #}
    <main class="wiki-main">
      <nav aria-label="Breadcrumb" class="wiki-main__breadcrumb">
        <ul class="uk-breadcrumb">
          {% for crumb in breadcrumbs %}
            <li{% if loop.last %} class="uk-active" aria-current="page"{% endif %}>
              {% if not loop.last %}
                <a href="{{ crumb.url }}">{{ crumb.label }}</a>
              {% else %}
                <span>{{ crumb.label }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="wiki-main__header">
        {% if logoUrl %}
          <div class="wiki-main__logo">
            <img src="{{ logoUrl }}" alt="{{ page.getTitle() }} Logo" loading="lazy">
          </div>
        {% endif %}
        <h1 class="wiki-main__title">{{ menuLabel }}</h1>
        <p class="wiki-main__subtitle">Antworten, Schritt-f&uuml;r-Schritt-Anleitungen und Hintergrundwissen zur {{ page.getTitle() }}.</p>
      </div>

      {% if articles is not empty %}
        <div class="wiki-articles">
          {% for article in articles %}
            <a class="wiki-article-row" href="{{ wikiBasePath }}/{{ article.getSlug() }}">
              <div>
                <p class="wiki-article-row__title">{{ article.getTitle() }}</p>
                {% if article.getExcerpt() %}
                  <p class="wiki-article-row__excerpt">{{ article.getExcerpt() }}</p>
                {% endif %}
              </div>
              {% set displayDate = article.getUpdatedAt() ?? article.getPublishedAt() %}
              {% if displayDate %}
                <span class="wiki-article-row__date">{{ displayDate|date('d.m.Y') }}</span>
              {% endif %}
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="wiki-empty">
          <p>Keine Artikel gefunden.</p>
        </div>
      {% endif %}
    </main>
  </div>
{% endblock %}
