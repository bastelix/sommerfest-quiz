{% extends 'layout.twig' %}

{% set themeDefaults = {
  'bodyClasses': ['marketing-wiki', 'marketing-wiki--detail'],
  'stylesheets': [],
  'colors': {}
} %}
{% set bodyClasses = themeDefaults.bodyClasses %}
{% set stylesheets = themeDefaults.stylesheets %}
{% set themeColors = {} %}
{% set logoUrl = wikiTheme.logoUrl|default(null) %}
{% if wikiTheme is defined %}
  {% if wikiTheme.bodyClasses is defined and wikiTheme.bodyClasses is iterable %}
    {% set bodyClasses = wikiTheme.bodyClasses %}
    {% if 'marketing-wiki--detail' not in bodyClasses %}
      {% set bodyClasses = bodyClasses|merge(['marketing-wiki--detail']) %}
    {% endif %}
  {% endif %}
  {% if wikiTheme.stylesheets is defined and wikiTheme.stylesheets is iterable %}
    {% set stylesheets = wikiTheme.stylesheets %}
  {% endif %}
  {% if wikiTheme.colors is defined %}
    {% set themeColors = wikiTheme.colors %}
  {% endif %}
  {% if wikiTheme.logoUrl is defined %}
    {% set logoUrl = wikiTheme.logoUrl %}
  {% endif %}
{% endif %}

{% block title %}{{ article.getTitle() }} – {{ menuLabel }}{% endblock %}

{% block body_class %}marketing-page {{ bodyClasses|join(' ') }}{% endblock %}

{% block head %}
  <link rel="preload" href="{{ basePath }}/css/marketing.css" as="style">
  <link rel="stylesheet" href="{{ basePath }}/css/marketing.css">
  <link rel="stylesheet" href="{{ basePath }}/css/highcontrast.css">
  <script type="module" src="{{ basePath }}/js/marketing-design.js"></script>
  {% for stylesheet in stylesheets %}
    {% set href = stylesheet matches '/^https?:\\/\\//i' or stylesheet starts with('//') ? stylesheet : (stylesheet starts with('/') ? stylesheet : basePath ~ '/css/' ~ stylesheet) %}
    <link rel="stylesheet" href="{{ href }}">
  {% endfor %}
  {% include 'marketing/partials/theme-vars.twig' with {
    appearance: appearance|default({}),
    design: design|default({}),
    normalizedNamespace: designNamespace|default('default')
  } only %}
  <style>
    /* ── Notion-inspired wiki layout ── */
    .wiki-layout {
      display: grid;
      grid-template-columns: 280px 1fr;
      min-height: calc(100vh - 120px);
      background: var(--marketing-background, var(--surface-page, #f7f9fb));
    }

    @media (max-width: 959px) {
      .wiki-layout {
        grid-template-columns: 1fr;
      }
    }

    /* ── Sidebar ── */
    .wiki-sidebar {
      background: var(--marketing-surface-muted, var(--surface-muted, #eef2f7));
      border-right: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
      padding: 24px 16px;
      overflow-y: auto;
      position: sticky;
      top: 0;
      height: 100vh;
    }

    @media (max-width: 959px) {
      .wiki-sidebar {
        position: static;
        height: auto;
        border-right: none;
        border-bottom: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
        padding: 16px;
      }
    }

    .wiki-sidebar__title {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #4b5563));
      padding: 0 8px;
      margin: 0 0 8px;
    }

    .wiki-sidebar__back {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 8px;
      border-radius: 6px;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #6b7280));
      font-size: 0.8125rem;
      text-decoration: none;
      transition: background 0.12s ease, color 0.12s ease;
      margin-bottom: 12px;
    }

    .wiki-sidebar__back:hover {
      background: color-mix(in srgb, var(--marketing-primary, var(--brand-primary, #1e87f0)) 8%, transparent);
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      text-decoration: none;
    }

    .wiki-sidebar__nav {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .wiki-sidebar__nav-item {
      margin: 0;
    }

    .wiki-sidebar__nav-link {
      display: block;
      padding: 6px 8px;
      border-radius: 6px;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      font-size: 0.875rem;
      line-height: 1.4;
      text-decoration: none;
      transition: background 0.12s ease;
    }

    .wiki-sidebar__nav-link:hover {
      background: color-mix(in srgb, var(--marketing-primary, var(--brand-primary, #1e87f0)) 8%, transparent);
      text-decoration: none;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
    }

    .wiki-sidebar__nav-link--active {
      background: color-mix(in srgb, var(--marketing-primary, var(--brand-primary, #1e87f0)) 12%, transparent);
      color: var(--marketing-primary, var(--brand-primary, #1e87f0));
      font-weight: 500;
    }

    /* ── Main content area ── */
    .wiki-main {
      padding: 40px 48px;
      max-width: 800px;
    }

    @media (max-width: 959px) {
      .wiki-main {
        padding: 24px 16px;
      }
    }

    .wiki-main__breadcrumb {
      margin-bottom: 24px;
    }

    .wiki-main__breadcrumb .uk-breadcrumb > li:nth-child(n+2)::before {
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #9ca3af));
    }

    .wiki-main__breadcrumb .uk-breadcrumb > li > a {
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #6b7280));
      font-size: 0.875rem;
    }

    .wiki-main__breadcrumb .uk-breadcrumb > li.uk-active > span {
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      font-size: 0.875rem;
    }

    .wiki-main__logo {
      margin-bottom: 16px;
    }

    .wiki-main__logo img {
      max-height: 48px;
      width: auto;
    }

    /* ── Article header ── */
    .wiki-article-header {
      margin-bottom: 32px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
    }

    .wiki-article-header__title {
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      font-weight: 700;
      color: var(--marketing-text-on-surface, var(--text-heading, #0b1728));
      margin: 0 0 8px;
      line-height: 1.2;
    }

    .wiki-article-header__meta {
      font-size: 0.8125rem;
      color: var(--marketing-text-muted-on-surface, var(--text-muted, #6b7280));
      margin: 0;
    }

    /* ── Article content (Notion-style typography) ── */
    .wiki-article-content {
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      font-size: 1rem;
      line-height: 1.7;
    }

    .wiki-article-content h2 {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--marketing-text-on-surface, var(--text-heading, #0b1728));
      margin: 2rem 0 0.75rem;
    }

    .wiki-article-content h3 {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--marketing-text-on-surface, var(--text-heading, #0b1728));
      margin: 1.5rem 0 0.5rem;
    }

    .wiki-article-content p {
      margin: 0 0 1rem;
    }

    .wiki-article-content img {
      max-width: 100%;
      height: auto;
      border-radius: 6px;
      margin: 1rem 0;
    }

    .wiki-article-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-size: 0.9rem;
      font-family: inherit;
    }

    .wiki-article-content table th {
      text-align: left;
      font-weight: 600;
      border-bottom: 2px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
      padding: 0.5rem 0.75rem;
    }

    .wiki-article-content table td {
      padding: 0.4rem 0.75rem;
      border-bottom: 1px solid color-mix(in srgb, var(--marketing-border-light, var(--border-muted, #dfe3eb)) 60%, transparent);
      vertical-align: top;
    }

    .wiki-article-content table tr:last-child td {
      border-bottom: none;
    }

    .wiki-article-content table code {
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace);
      font-size: 0.85em;
      background: var(--marketing-surface-muted, var(--surface-muted, #f1f5f9));
      padding: 0.1em 0.3em;
      border-radius: 3px;
    }

    .wiki-article-content blockquote,
    .wiki-article-content .wiki-callout {
      border-left: 3px solid var(--marketing-primary, var(--brand-primary, #1e87f0));
      padding: 12px 16px;
      background: color-mix(in srgb, var(--marketing-primary, var(--brand-primary, #1e87f0)) 5%, var(--marketing-surface, var(--surface-card, #ffffff)));
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      margin: 1.5rem 0;
      border-radius: 0 6px 6px 0;
    }

    .wiki-article-content blockquote strong,
    .wiki-article-content .wiki-callout strong {
      display: block;
      margin-bottom: 4px;
    }

    .wiki-article-content code {
      background: var(--marketing-surface-muted, var(--surface-muted, #f1f5f9));
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.875em;
    }

    .wiki-article-content pre {
      background: var(--marketing-surface-muted, var(--surface-muted, #f1f5f9));
      padding: 16px;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    .wiki-article-content pre code {
      background: none;
      padding: 0;
    }

    .wiki-article-content ul,
    .wiki-article-content ol {
      padding-left: 1.5em;
      margin: 0 0 1rem;
    }

    .wiki-article-content li {
      margin-bottom: 0.25rem;
    }

    /* ── Footer navigation ── */
    .wiki-article-footer {
      margin-top: 48px;
      padding-top: 24px;
      border-top: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }

    .wiki-article-footer__link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: 6px;
      font-size: 0.875rem;
      text-decoration: none;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
      border: 1px solid var(--marketing-border-light, var(--border-muted, #dfe3eb));
      transition: background 0.12s ease, border-color 0.12s ease;
    }

    .wiki-article-footer__link:hover {
      background: var(--marketing-surface-muted, var(--surface-muted, #f1f5f9));
      border-color: var(--marketing-primary, var(--brand-primary, #1e87f0));
      text-decoration: none;
      color: var(--marketing-text-on-surface, var(--text-body, #111827));
    }
  </style>
{% endblock %}

{% block body %}
  {% include 'marketing/partials/design-data.twig' %}
  <div class="wiki-layout">
    {# ── Sidebar with article navigation ── #}
    <aside class="wiki-sidebar">
      {% if logoUrl %}
        <div class="wiki-main__logo uk-margin-small">
          <img src="{{ logoUrl }}" alt="{{ page.getTitle() }} Logo" loading="lazy">
        </div>
      {% endif %}
      <a class="wiki-sidebar__back" href="{{ basePath }}/pages/{{ page.getSlug() }}/wiki">
        <span uk-icon="icon: arrow-left; ratio: 0.75"></span>
        {{ menuLabel }}
      </a>
      <p class="wiki-sidebar__title">Artikel</p>
      <ul class="wiki-sidebar__nav">
        {% for sidebarArticle in articles|default([]) %}
          <li class="wiki-sidebar__nav-item">
            <a class="wiki-sidebar__nav-link{% if sidebarArticle.getSlug() == article.getSlug() %} wiki-sidebar__nav-link--active{% endif %}"
               href="{{ basePath }}/pages/{{ page.getSlug() }}/wiki/{{ sidebarArticle.getSlug() }}">
              {{ sidebarArticle.getTitle() }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </aside>

    {# ── Main content ── #}
    <main class="wiki-main">
      <nav aria-label="Breadcrumb" class="wiki-main__breadcrumb">
        <ul class="uk-breadcrumb">
          {% for crumb in breadcrumbs %}
            <li{% if loop.last %} class="uk-active" aria-current="page"{% endif %}>
              {% if not loop.last %}
                <a href="{{ crumb.url }}">{{ crumb.label }}</a>
              {% else %}
                <span>{{ crumb.label }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="wiki-article-header">
        <h1 class="wiki-article-header__title">{{ article.getTitle() }}</h1>
        {% set displayDate = article.getUpdatedAt() ?? article.getPublishedAt() %}
        {% if displayDate %}
          <p class="wiki-article-header__meta">Zuletzt aktualisiert am {{ displayDate|date('d.m.Y') }}</p>
        {% endif %}
      </div>

      <article class="wiki-article-content">
        {{ article.getContentHtml()|raw }}
      </article>

      <div class="wiki-article-footer">
        <a class="wiki-article-footer__link" href="{{ basePath }}/pages/{{ page.getSlug() }}/wiki">
          <span uk-icon="icon: arrow-left; ratio: 0.75"></span>
          Zur&uuml;ck zur &Uuml;bersicht
        </a>
        <a class="wiki-article-footer__link" href="{{ basePath }}/pages/{{ page.getSlug() }}">
          Zur Marketing-Seite
        </a>
      </div>
    </main>
  </div>
{% endblock %}
