{% extends 'layout.twig' %}

{% set themeDefaults = {
  'bodyClasses': ['marketing-wiki', 'marketing-wiki--detail'],
  'stylesheets': [],
  'colors': {}
} %}
{% set bodyClasses = themeDefaults.bodyClasses %}
{% set stylesheets = themeDefaults.stylesheets %}
{% set themeColors = {} %}
{% set logoUrl = wikiTheme.logoUrl|default(null) %}
{% if wikiTheme is defined %}
  {% if wikiTheme.bodyClasses is defined and wikiTheme.bodyClasses is iterable %}
    {% set bodyClasses = wikiTheme.bodyClasses %}
    {% if 'marketing-wiki--detail' not in bodyClasses %}
      {% set bodyClasses = bodyClasses|merge(['marketing-wiki--detail']) %}
    {% endif %}
  {% endif %}
  {% if wikiTheme.stylesheets is defined and wikiTheme.stylesheets is iterable %}
    {% set stylesheets = wikiTheme.stylesheets %}
  {% endif %}
  {% if wikiTheme.colors is defined %}
    {% set themeColors = wikiTheme.colors %}
  {% endif %}
  {% if wikiTheme.logoUrl is defined %}
    {% set logoUrl = wikiTheme.logoUrl %}
  {% endif %}
{% endif %}

{% block title %}{{ article.getTitle() }} – {{ menuLabel }}{% endblock %}

{% block body_class %}marketing-page {{ bodyClasses|join(' ') }}{% endblock %}

{% block site_header %}
  {% if cmsMainNavigation is defined and cmsMainNavigation is not empty %}
    {% include 'pages/partials/header.twig' with {
      normalizedNamespace: designNamespace|default('default'),
      headerTheme: 'light',
      headerLogo: headerLogo|default({}),
      cmsMenuItems: [],
      cmsMainNavigation: cmsMainNavigation|default([]),
      headerConfig: headerConfig|default({}),
      basePath: basePath,
      cmsSlug: cmsSlug|default(''),
      pageTitle: pageTitle|default('QuizRace')
    } only %}
  {% endif %}
{% endblock %}

{% block head %}
  <link rel="preload" href="{{ basePath }}/css/marketing.css" as="style">
  <link rel="stylesheet" href="{{ basePath }}/css/marketing.css">
  <link rel="stylesheet" href="{{ basePath }}/css/highcontrast.css">
  <link rel="stylesheet" href="{{ basePath }}/css/topbar.marketing.css">
  <link rel="stylesheet" href="{{ basePath }}/css/wiki.css">
  <link rel="stylesheet" href="{{ basePath }}/css/wiki-material.css">
  <script type="module" src="{{ basePath }}/js/marketing-design.js"></script>
  <script defer src="{{ basePath }}/js/wiki-material.js"></script>
  {% for stylesheet in stylesheets %}
    {% set href = stylesheet matches '/^https?:\\/\\//i' or stylesheet starts with('//') ? stylesheet : (stylesheet starts with('/') ? stylesheet : basePath ~ '/css/' ~ stylesheet) %}
    <link rel="stylesheet" href="{{ href }}">
  {% endfor %}
  {% include 'marketing/partials/theme-vars.twig' with {
    appearance: appearance|default({}),
    design: design|default({}),
    normalizedNamespace: designNamespace|default('default')
  } only %}
{% endblock %}

{% block body %}
  {% include 'marketing/partials/design-data.twig' %}
  <div class="wiki-layout">
    {# ── Mobile sidebar overlay + toggle ── #}
    <div class="wiki-sidebar-overlay"></div>
    <button class="wiki-sidebar-toggle" aria-label="Navigation öffnen">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    </button>

    {# ── Sidebar with article navigation ── #}
    <aside class="wiki-sidebar">
      {% if logoUrl %}
        <div class="wiki-sidebar__logo">
          <img src="{{ logoUrl }}" alt="{{ page.getTitle() }} Logo" loading="lazy">
        </div>
      {% endif %}
      <a class="wiki-sidebar__back" href="{{ pageUrl|default(basePath ~ '/pages/' ~ page.getSlug()) }}">
        <span uk-icon="icon: arrow-left; ratio: 0.7"></span>
        {{ page.getTitle() }}
      </a>
      <p class="wiki-sidebar__label">{{ menuLabel }}</p>
      <ul class="wiki-sidebar__nav">
        {% for sidebarArticle in articles|default([]) %}
          <li class="wiki-sidebar__nav-item">
            <a class="wiki-sidebar__nav-link{% if sidebarArticle.getSlug() == article.getSlug() %} wiki-sidebar__nav-link--active{% endif %}"
               href="{{ wikiBasePath }}/{{ sidebarArticle.getSlug() }}">
              {{ sidebarArticle.getTitle() }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </aside>

    {# ── Main content ── #}
    <main class="wiki-main">
      <nav aria-label="Breadcrumb" class="wiki-main__breadcrumb">
        <ul class="uk-breadcrumb">
          {% for crumb in breadcrumbs %}
            <li{% if loop.last %} class="uk-active" aria-current="page"{% endif %}>
              {% if not loop.last %}
                <a href="{{ crumb.url }}">{{ crumb.label }}</a>
              {% else %}
                <span>{{ crumb.label }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="wiki-article-header">
        <h1 class="wiki-article-header__title">{{ article.getTitle() }}</h1>
        {% set displayDate = article.getUpdatedAt() ?? article.getPublishedAt() %}
        {% if displayDate %}
          <p class="wiki-article-header__meta">Zuletzt aktualisiert am {{ displayDate|date('d.m.Y') }}</p>
        {% endif %}
      </div>

      <article class="wiki-article-content">
        {{ article.getContentHtml()|raw }}
      </article>

      <div class="wiki-article-footer">
        <a class="wiki-article-footer__link" href="{{ wikiBasePath }}">
          <span uk-icon="icon: arrow-left; ratio: 0.7"></span>
          Zur&uuml;ck zur &Uuml;bersicht
        </a>
        <a class="wiki-article-footer__link" href="{{ pageUrl|default(basePath ~ '/pages/' ~ page.getSlug()) }}">
          Zur Marketing-Seite
        </a>
      </div>
    </main>

    {# ── Footer ── #}
    <footer class="wiki-page-footer">
      <span>&copy; {{ page.getTitle() }}</span>
      {% set displayDate = article.getUpdatedAt() ?? article.getPublishedAt() %}
      {% if displayDate %}
        <span>Zuletzt aktualisiert: {{ displayDate|date('d.m.Y') }}</span>
      {% endif %}
    </footer>
  </div>
{% endblock %}
