{# Renders the "timeline" page module.
   Expects: module (PageModule).
   Config keys: heading (string), items (array of {title, description, duration, icon}),
                closing (optional {title, body}), variant (optional: "cards"). #}
{% set moduleConfig = module.config|default({}) %}
{% set heading = moduleConfig.heading|default('') %}
{% set items = moduleConfig.items|default([]) %}
{% set closing = moduleConfig.closing|default({}) %}
{% set variant = moduleConfig.variant|default('default') %}

{% if items|length > 0 %}
  <section class="marketing-section uk-section uk-section-muted page-module-timeline"
           data-page-module-id="{{ module.id|e('html_attr') }}"
           data-page-module-type="timeline">
    <div class="uk-container">
      {% if heading %}
        <h2 class="uk-heading-medium uk-margin-medium-bottom{% if variant == 'cards' %} uk-text-center{% endif %}">{{ heading }}</h2>
      {% endif %}

      {% if variant == 'cards' %}
        {# ── Alternating cards timeline ── #}
        <ul class="tl-cards" role="list" aria-label="{{ heading|default('Timeline')|e('html_attr') }}">
          {% for item in items %}
            {% set stepId = 'timeline-' ~ module.id ~ '-step-' ~ loop.index %}
            {% set side = loop.index is odd ? 'left' : 'right' %}
            <li class="tl-cards__step tl-cards__step--{{ side }}" role="listitem"
                aria-labelledby="{{ stepId }}-title" aria-describedby="{{ stepId }}-desc">
              <div class="tl-cards__dot{% if item.icon|default('') %} tl-cards__dot--icon{% endif %}" aria-hidden="true">
                {% if item.icon|default('') %}
                  <span class="tl-cards__dot-icon" data-uk-icon="icon: {{ item.icon|e('html_attr') }}"></span>
                {% else %}
                  <span class="tl-cards__dot-index">{{ loop.index }}</span>
                {% endif %}
              </div>
              <div class="tl-cards__card">
                {% if item.duration|default('') %}
                  <span class="tl-cards__year">{{ item.duration|e }}</span>
                {% endif %}
                <h3 id="{{ stepId }}-title" class="tl-cards__title">{{ item.title|default('')|e }}</h3>
                <p id="{{ stepId }}-desc" class="tl-cards__text">{{ item.description|default('')|e }}</p>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        {# ── Default vertical timeline ── #}
        <ul class="trust-story trust-story--timeline" role="list" aria-label="{{ heading|default('Timeline')|e('html_attr') }}">
          {% for item in items %}
            {% set stepId = 'timeline-' ~ module.id ~ '-step-' ~ loop.index %}
            <li class="trust-story__step" role="listitem" tabindex="0"
                aria-labelledby="{{ stepId }}-title" aria-describedby="{{ stepId }}-desc">
              <div class="trust-story__marker" aria-hidden="true">
                <span class="trust-story__connector trust-story__connector--before"></span>
                <span class="trust-story__badge{% if item.icon|default('') %} trust-story__badge--icon{% endif %}" data-step-index="{{ loop.index }}">
                  {% if item.icon|default('') %}
                    <span class="trust-story__badge-icon" aria-hidden="true" data-uk-icon="icon: {{ item.icon|e('html_attr') }}"></span>
                  {% else %}
                    {{ loop.index }}
                  {% endif %}
                  <span class="trust-story__sr">Schritt {{ loop.index }}</span>
                </span>
                <span class="trust-story__connector trust-story__connector--after"></span>
              </div>
              <div class="trust-story__content">
                {% if item.duration|default('') %}
                  <span class="trust-story__duration">{{ item.duration|e }}</span>
                {% endif %}
                <h3 id="{{ stepId }}-title" class="trust-story__title">{{ item.title|default('')|e }}</h3>
                <p id="{{ stepId }}-desc" class="trust-story__text">{{ item.description|default('')|e }}</p>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if closing.title|default('') or closing.body|default('') %}
        <div class="{% if variant == 'cards' %}tl-cards__closing{% else %}trust-story__closing{% endif %}">
          {% if closing.title|default('') %}
            <h3 class="{% if variant == 'cards' %}uk-text-center uk-margin-medium-top{% else %}trust-story__closing-title{% endif %}">{{ closing.title|e }}</h3>
          {% endif %}
          {% if closing.body|default('') %}
            <p class="{% if variant == 'cards' %}uk-text-center uk-text-muted{% else %}trust-story__closing-text{% endif %}">{{ closing.body|e }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}
