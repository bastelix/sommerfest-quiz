{% extends 'layouts/cms_base.twig' %}

{% set newsBaseSlug = newsOwnerBaseSlug|default(page.slug) %}

{% set includeCmsBaseStyles = false %}
{% set includeMainStyles = false %}
{% set includeFrontendHydrator = false %}

{% block title %}{{ metaTitle|default(entry.title ~ ' – Neuigkeiten') }}{% endblock %}

{% block head %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ basePath }}/css/dark.css" media="all">
  <link rel="stylesheet" href="{{ basePath }}/css/highcontrast.css">
  <link rel="stylesheet" href="{{ basePath }}/css/sections.css">
  <link rel="preload" href="{{ basePath }}/css/marketing.css" as="style">
  <link rel="stylesheet" href="{{ basePath }}/css/marketing.css">
  <link rel="stylesheet" href="{{ basePath }}/css/marketing-cards.css">
  <link rel="stylesheet" href="{{ basePath }}/css/topbar.marketing.css">
  <link rel="stylesheet" href="{{ basePath }}/css/landing-news.css">
  <script type="module" src="{{ basePath }}/js/marketing-design.js" defer></script>
{% endblock %}

{% block body_class %}page-render cms-page-render marketing-page uk-background-default{% endblock %}

{% block body %}
  {% include 'marketing/partials/design-data.twig' %}
  <div class="marketing-layout">
    {% include 'pages/partials/header.twig' with {
      normalizedNamespace: designNamespace|default('default'),
      headerTheme: design.theme|default('light'),
      headerLogo: headerLogo|default({}),
      cmsMenuItems: cmsMainNavigation|default([]),
      cmsMainNavigation: cmsMainNavigation|default([]),
      headerConfig: headerConfig|default({}),
      basePath: basePath,
      cmsSlug: cmsSlug|default(newsOwnerSlug|default(page.slug)),
      pageTitle: page.title|default('edocs')
    } only %}

    {% if breadcrumbs is defined and breadcrumbs %}
      <nav aria-label="Breadcrumb" class="uk-container uk-margin-small-top">
        <ul class="uk-breadcrumb">
          {% for crumb in breadcrumbs %}
            <li{% if loop.last %} class="uk-active" aria-current="page"{% endif %}>
              {% if not loop.last and crumb.url %}
                <a href="{{ crumb.url }}">{{ crumb.label }}</a>
              {% else %}
                <span>{{ crumb.label }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <section id="landing-news" class="marketing-section uk-section uk-section-default landing-news-detail">
      <div class="landing-news-detail__container">
        <article class="landing-news-detail__article">
          <h1 class="landing-news-detail__title">{{ entry.title }}</h1>
          {% if entry.publishedAt %}
            <p class="landing-news-detail__date">{{ entry.publishedAt|date('d.m.Y') }}</p>
          {% endif %}
          {% if entry.imageUrl %}
            <div class="landing-news-detail__image">
              <img src="{{ entry.imageUrl }}" alt="{{ entry.title|e }}" loading="lazy">
            </div>
          {% endif %}
          {% if entry.excerpt %}
            <div class="landing-news-detail__excerpt">{{ entry.excerpt|raw }}</div>
          {% endif %}
          <div class="landing-news-detail__content">{{ entry.content|raw }}</div>
          <div class="landing-news-detail__back">
            <a href="{{ basePath }}/{{ newsBaseSlug }}/news">&larr; Zurück zur Übersicht</a>
          </div>
        </article>
      </div>
    </section>
  </div>
{% endblock %}
