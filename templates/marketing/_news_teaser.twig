{% set detailPath = newsBasePath is defined and newsBasePath ? newsBasePath ~ '/' ~ entry.slug : null %}
{% set linkHref = detailPath ? basePath ~ detailPath : null %}
<article class="landing-news-card">
  {% if entry.imageUrl %}
    <div class="landing-news-card__image">
      {% if linkHref %}
        <a href="{{ linkHref }}" tabindex="-1" aria-hidden="true">
          <img src="{{ entry.imageUrl }}" alt="{{ entry.title|e }}" loading="lazy">
        </a>
      {% else %}
        <img src="{{ entry.imageUrl }}" alt="{{ entry.title|e }}" loading="lazy">
      {% endif %}
    </div>
  {% endif %}
  {% set published = entry.publishedAt %}
  {% if published %}
    <p class="landing-news-card__date">{{ published|date('d.m.Y') }}</p>
  {% endif %}
  <h3 class="landing-news-card__title">
    {% if linkHref %}
      <a href="{{ linkHref }}">{{ entry.title|replace({': ': ': <wbr>'})|raw }}</a>
    {% else %}
      {{ entry.title }}
    {% endif %}
  </h3>
  {% if entry.excerpt %}
    <p class="landing-news-card__excerpt">{{ entry.excerpt|striptags }}</p>
  {% endif %}
  {% if linkHref %}
    <a class="landing-news-card__readmore" href="{{ linkHref }}">Weiterlesen &rarr;</a>
  {% endif %}
</article>
