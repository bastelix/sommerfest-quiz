<div class="uk-card uk-card-default uk-card-body uk-margin">
  <div class="uk-flex uk-flex-between uk-flex-middle uk-flex-wrap">
    <h3 class="uk-card-title uk-margin-remove">{{ t('heading_namespace_overview') }}</h3>
    <span class="uk-text-meta">{{ t('label_project_namespace') }} · {{ t('menu_content') }}</span>
  </div>
  <p class="uk-text-meta uk-margin-small-top">
    {{ t('text_namespace_overview_description') }}
  </p>
  <p class="uk-text-meta uk-margin-small-top">
    {{ t('text_namespace_overview_empty_hint') }}
  </p>
  <div class="uk-text-meta uk-margin-small-top">
    <span class="uk-margin-small-right">{{ t('label_namespace_status_legend') }}</span>
    <span class="uk-label uk-label-default uk-margin-small-right">{{ t('label_namespace_default') }}</span>
    <span class="uk-label uk-label-danger uk-margin-small-right">{{ t('label_namespace_inactive') }}</span>
  </div>
  <div class="uk-flex uk-flex-middle uk-flex-wrap uk-margin-small-bottom page-tree-toolbar" data-project-tree-toolbar>
    <div class="uk-inline uk-width-1-1 uk-width-1-2@m">
      <span class="uk-form-icon" uk-icon="icon: search"></span>
      <input class="uk-input uk-form-small" type="text"
             data-page-tree-search
             placeholder="{{ t('placeholder_search_pages')|default('Seiten durchsuchen…') }}">
    </div>
    <button
      class="uk-button uk-button-default uk-button-small uk-margin-small-left"
      type="button"
      data-page-tree-expand-all="collapse"
    >{{ t('action_collapse_all')|default('Alle einklappen') }}</button>
  </div>
  <div
    class="project-tree"
    data-project-tree
    data-endpoint="{{ basePath }}/admin/projects/tree"
    data-base-url="{{ basePath }}"
    data-initial-payload="{{ project_tree_payload|default([])|json_encode|e('html_attr') }}"
    data-namespace="{{ pageNamespace|default('default')|e('html_attr') }}"
    data-empty="{{ t('text_namespace_overview_empty') }}"
    data-error="{{ t('error_namespace_overview_load') }}"
  >
    <div class="uk-text-meta" data-project-tree-loading>{{ t('text_namespace_overview_loading') }}</div>
  </div>
</div>
