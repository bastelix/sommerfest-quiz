{% extends 'admin/base.twig' %}

{% set adminLayout = 'narrow' %}
{% set activePageNamespace = pageNamespace|default('default') %}
{% set pageNamespaceQuery = activePageNamespace is not empty ? '?namespace=' ~ activePageNamespace|url_encode : '' %}

{% block title %}Ticket #{{ ticket.id }} – {{ ticket.title }}{% endblock %}

{% block content %}
  <div class="uk-container uk-container-large">
    <div class="uk-padding-small uk-padding-remove-horizontal">
      <a href="{{ basePath }}/admin/tickets{{ pageNamespaceQuery }}" class="uk-button uk-button-text uk-margin-small-bottom">&larr; Zurück zur Liste</a>
      <div class="uk-flex uk-flex-between uk-flex-middle">
        <h1 class="uk-heading-bullet uk-margin-remove">
          <span class="uk-text-muted">#{{ ticket.id }}</span> {{ ticket.title }}
        </h1>
        <div>
          <a class="uk-button uk-button-default uk-button-small" href="{{ basePath }}/admin/tickets/{{ ticket.id }}/edit{{ pageNamespaceQuery }}">Bearbeiten</a>
          <form method="post" action="{{ basePath }}/admin/tickets/{{ ticket.id }}/delete{{ pageNamespaceQuery }}" style="display:inline;" onsubmit="return confirm('Ticket wirklich löschen?');">
            <input type="hidden" name="_token" value="{{ csrfToken }}">
            <button type="submit" class="uk-button uk-button-danger uk-button-small">Löschen</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="uk-container uk-container-expand">
    <div class="uk-grid-small" uk-grid>
      {# ── Left column: Details ───────────────────────────────── #}
      <div class="uk-width-2-3@m">
        {# Description #}
        <div class="uk-card uk-card-default uk-card-body uk-margin-small">
          <h3 class="uk-card-title">Beschreibung</h3>
          {% if ticket.description %}
            <div class="uk-text-break" style="white-space: pre-wrap;">{{ ticket.description|e }}</div>
          {% else %}
            <p class="uk-text-muted">Keine Beschreibung vorhanden.</p>
          {% endif %}
        </div>

        {# Comments #}
        <div class="uk-card uk-card-default uk-card-body uk-margin-small">
          <h3 class="uk-card-title">Kommentare ({{ comments|length }})</h3>

          {% for comment in comments %}
            <article class="uk-comment uk-margin-medium-bottom" style="border-left: 3px solid #e5e5e5; padding-left: 1rem;">
              <header class="uk-comment-header uk-margin-small-bottom">
                <div class="uk-flex uk-flex-between uk-flex-middle">
                  <div>
                    <span class="uk-text-bold">{{ comment.author }}</span>
                    <span class="uk-text-meta uk-margin-small-left">{{ comment.createdAt|date('d.m.Y H:i') }}</span>
                  </div>
                  <form method="post" action="{{ basePath }}/admin/tickets/{{ ticket.id }}/comment/{{ comment.id }}/delete{{ pageNamespaceQuery }}" onsubmit="return confirm('Kommentar löschen?');">
                    <input type="hidden" name="_token" value="{{ csrfToken }}">
                    <button type="submit" class="uk-button uk-button-text uk-text-danger uk-button-small" title="Löschen">
                      <span uk-icon="icon: trash; ratio: 0.8"></span>
                    </button>
                  </form>
                </div>
              </header>
              <div class="uk-comment-body" style="white-space: pre-wrap;">{{ comment.body|e }}</div>
            </article>
          {% else %}
            <p class="uk-text-muted">Noch keine Kommentare.</p>
          {% endfor %}

          {# Add comment form #}
          <hr>
          <form method="post" action="{{ basePath }}/admin/tickets/{{ ticket.id }}/comment{{ pageNamespaceQuery }}" class="uk-form-stacked">
            <input type="hidden" name="_token" value="{{ csrfToken }}">
            <div class="uk-margin-small">
              <textarea name="body" class="uk-textarea" rows="3" placeholder="Kommentar schreiben..." required></textarea>
            </div>
            <button type="submit" class="uk-button uk-button-primary uk-button-small">Kommentar hinzufügen</button>
          </form>
        </div>
      </div>

      {# ── Right column: Metadata + Actions ───────────────────── #}
      <div class="uk-width-1-3@m">
        {# Status + Transitions #}
        <div class="uk-card uk-card-default uk-card-body uk-margin-small">
          <h3 class="uk-card-title">Status</h3>
          <div class="uk-margin-small-bottom">
            {% if ticket.status == 'open' %}
              <span class="uk-label">Offen</span>
            {% elseif ticket.status == 'in_progress' %}
              <span class="uk-label uk-label-warning">In Bearbeitung</span>
            {% elseif ticket.status == 'resolved' %}
              <span class="uk-label uk-label-success">Gelöst</span>
            {% elseif ticket.status == 'closed' %}
              <span class="uk-label" style="background:#999;">Geschlossen</span>
            {% endif %}
          </div>

          {% if transitions|length > 0 %}
            <div class="uk-margin-small-top">
              <p class="uk-text-meta uk-margin-remove">Status ändern:</p>
              {% for target in transitions %}
                <form method="post" action="{{ basePath }}/admin/tickets/{{ ticket.id }}/transition{{ pageNamespaceQuery }}" style="display:inline;" class="uk-margin-small-right">
                  <input type="hidden" name="_token" value="{{ csrfToken }}">
                  <input type="hidden" name="status" value="{{ target }}">
                  <button type="submit" class="uk-button uk-button-default uk-button-small uk-margin-small-top">
                    {% if target == 'open' %}Wiedereröffnen
                    {% elseif target == 'in_progress' %}In Bearbeitung
                    {% elseif target == 'resolved' %}Als gelöst markieren
                    {% elseif target == 'closed' %}Schließen
                    {% endif %}
                  </button>
                </form>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {# Metadata #}
        <div class="uk-card uk-card-default uk-card-body uk-margin-small">
          <h3 class="uk-card-title">Details</h3>
          <dl class="uk-description-list uk-description-list-divider">
            <dt>Priorität</dt>
            <dd>
              {% if ticket.priority == 'critical' %}
                <span class="uk-label uk-label-danger">Kritisch</span>
              {% elseif ticket.priority == 'high' %}
                <span class="uk-label uk-label-warning">Hoch</span>
              {% elseif ticket.priority == 'normal' %}
                Normal
              {% else %}
                Niedrig
              {% endif %}
            </dd>

            <dt>Typ</dt>
            <dd>
              {% if ticket.type == 'bug' %}Bug
              {% elseif ticket.type == 'task' %}Aufgabe
              {% elseif ticket.type == 'review' %}Review
              {% else %}Verbesserung
              {% endif %}
            </dd>

            <dt>Zugewiesen</dt>
            <dd>{{ ticket.assignee|default('Nicht zugewiesen') }}</dd>

            <dt>Erstellt von</dt>
            <dd>{{ ticket.createdBy|default('Unbekannt') }}</dd>

            <dt>Erstellt am</dt>
            <dd>{{ ticket.createdAt|date('d.m.Y H:i') }}</dd>

            <dt>Aktualisiert am</dt>
            <dd>{{ ticket.updatedAt|date('d.m.Y H:i') }}</dd>

            {% if ticket.dueDate %}
              <dt>Fällig am</dt>
              <dd>{{ ticket.dueDate|date('d.m.Y') }}</dd>
            {% endif %}

            {% if ticket.labels|length > 0 %}
              <dt>Labels</dt>
              <dd>
                {% for label in ticket.labels %}
                  <span class="uk-label uk-label-default" style="font-size: 0.75rem; margin-right: 0.25rem;">{{ label }}</span>
                {% endfor %}
              </dd>
            {% endif %}
          </dl>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block scripts %}
  <script src="{{ basePath }}/js/storage.js"></script>
  <script type="module" src="{{ basePath }}/js/admin.js"></script>
{% endblock %}
