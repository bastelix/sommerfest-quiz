{% extends 'admin/base.twig' %}

{% set adminLayout = 'narrow' %}

{% set isEdit = entry is not null %}
{% set formValues = override|default({}) %}
{% set pageId = formValues.page_id|default(isEdit ? entry.pageId : '') %}
{% set titleValue = formValues.title|default(isEdit ? entry.title : '') %}
{% set excerptValue = formValues.excerpt|default(isEdit ? entry.excerpt : '') %}
{% set contentValue = formValues.content|default(isEdit ? entry.content : '') %}
{% set published = formValues.is_published is defined ? formValues.is_published : (isEdit ? entry.isPublished : false) %}
{% set publishedAt = formValues.published_at|default(isEdit and entry.publishedAt ? entry.publishedAt|date('Y-m-d\\TH:i') : '') %}
{% set slug = formValues.slug|default(isEdit ? entry.slug : '') %}
{% set imageUrl = formValues.image_url|default(isEdit ? entry.imageUrl : '') %}
{% set pageNamespace = pageNamespace|default('') %}
{% set namespaceQuery = pageNamespace is not empty ? '?namespace=' ~ pageNamespace|url_encode : '' %}
{% set formAction = (isEdit ? basePath ~ '/admin/landing-news/' ~ entry.id : basePath ~ '/admin/landing-news') ~ namespaceQuery %}

{% block title %}{{ isEdit ? t('heading_news_edit') : t('heading_news_create') }}{% endblock %}

{% block content %}
  <div class="uk-container uk-container-large">
    <div class="uk-padding-small uk-padding-remove-horizontal">
      <h1 class="uk-heading-bullet uk-margin-remove">{{ isEdit ? t('heading_news_edit') : t('heading_news_create') }}</h1>
    </div>
  </div>
  <div class="uk-container uk-container-expand">
    <form method="post" action="{{ formAction }}" class="uk-form-stacked uk-grid-small" uk-grid data-is-edit="{{ isEdit ? 'true' : 'false' }}" data-namespace="{{ pageNamespace|e }}" data-base-path="{{ basePath|e }}">
      <input type="hidden" name="_token" value="{{ csrfToken }}">

      {# ── Primary: Title + Content ─────────────────────────── #}
      <div class="uk-width-1-1">
        <label class="uk-form-label" for="newsTitle">{{ t('label_news_title') }}</label>
        <div class="uk-form-controls">
          <input id="newsTitle" class="uk-input" type="text" name="title" value="{{ titleValue|e }}" required>
        </div>
      </div>
      <div class="uk-width-1-1">
        <label class="uk-form-label" for="newsContent">{{ t('label_news_content') }}</label>
        <div class="uk-form-controls">
          <div id="newsContentEditor" class="news-content-editor"></div>
          <textarea id="newsContent" name="content" style="display:none" required>{{ contentValue|e }}</textarea>
        </div>
      </div>

      {# ── Publish settings ─────────────────────────────────── #}
      <div class="uk-width-1-1 uk-width-1-2@m">
        <label class="uk-form-label" for="landingPage">{{ t('label_news_page') }}</label>
        <div class="uk-form-controls">
          <select id="landingPage" name="page_id" class="uk-select" required>
            <option value="">{{ t('placeholder_select_page') }}</option>
            {% for page in pages %}
              <option value="{{ page.id }}" {% if page.id == pageId %}selected{% endif %}>{{ page.title }} ({{ page.slug }})</option>
            {% endfor %}
          </select>
        </div>
      </div>
      {% if categories is defined and categories|length > 0 %}
        <div class="uk-width-1-1 uk-width-1-2@m uk-flex uk-flex-bottom">
          <div class="uk-width-1-1">
            <label class="uk-form-label">Kategorien</label>
            <div class="uk-form-controls">
              {% set selectedIds = override.category_ids|default(assignedCategoryIds|default([])) %}
              {% for cat in categories %}
                <label class="uk-margin-small-right" style="display: inline-flex; align-items: center; gap: 0.3rem;">
                  <input
                    class="uk-checkbox"
                    type="checkbox"
                    name="category_ids[]"
                    value="{{ cat.id }}"
                    {% if cat.id in selectedIds %}checked{% endif %}
                  >
                  {{ cat.name }}
                </label>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
      <div class="uk-width-1-1 uk-width-1-3@m">
        <label class="uk-form-label" for="newsPublishedAt">{{ t('label_news_published_at') }}</label>
        <div class="uk-form-controls">
          <input id="newsPublishedAt" class="uk-input" type="datetime-local" name="published_at" value="{{ publishedAt|e }}">
        </div>
      </div>
      <div class="uk-width-1-1 uk-width-1-3@m uk-flex uk-flex-middle">
        <label><input id="newsIsPublished" class="uk-checkbox" type="checkbox" name="is_published" value="1" {% if published %}checked{% endif %}> {{ t('label_news_is_published') }}</label>
      </div>

      {# ── Advanced options (collapsed by default on create) ── #}
      <div class="uk-width-1-1 uk-margin-small-top">
        <button type="button" id="toggleAdvanced" class="uk-button uk-button-text uk-text-small">
          <span id="toggleAdvancedIcon">&#9654;</span> Erweiterte Optionen
        </button>
      </div>
      <div id="advancedOptions" class="uk-width-1-1" {% if not isEdit and not slug and not excerptValue and not imageUrl %}style="display: none;"{% endif %}>
        <div class="uk-grid-small" uk-grid>
          <div class="uk-width-1-1 uk-width-expand@m">
            <label class="uk-form-label" for="newsSlug">{{ t('label_news_slug') }}</label>
            <div class="uk-form-controls uk-flex uk-flex-middle" style="gap: 0.5rem;">
              <input id="newsSlug" class="uk-input" type="text" name="slug" value="{{ slug|e }}" required pattern="[a-z0-9\-]+" maxlength="100">
              <button type="button" id="newsSlugSuggest" class="uk-button uk-button-default uk-button-small uk-text-nowrap" title="{{ t('label_news_title') }} &rarr; Slug">
                &circlearrowleft; Aus Titel
              </button>
            </div>
            <div class="uk-text-meta uk-margin-small-top">Wird automatisch aus dem Titel erzeugt, falls leer.</div>
          </div>
          <div class="uk-width-1-1">
            <label class="uk-form-label" for="newsExcerpt">{{ t('label_news_excerpt') }} <span class="uk-text-meta">(optional)</span></label>
            <div class="uk-form-controls">
              <textarea id="newsExcerpt" class="uk-textarea" name="excerpt" rows="3">{{ excerptValue|e }}</textarea>
            </div>
            <div class="uk-text-meta uk-margin-small-top">Wenn leer, wird der Anfang des Inhalts als Vorschautext verwendet.</div>
          </div>
          <div class="uk-width-1-1">
            <label class="uk-form-label" for="newsImageUrl">Beitragsbild <span class="uk-text-meta">(optional)</span></label>
            <div class="uk-form-controls">
              <div class="uk-flex uk-flex-middle uk-flex-wrap" style="gap: 0.5rem;">
                <input id="newsImageUrl" class="uk-input uk-flex-auto" type="text" name="image_url" value="{{ imageUrl|e }}" placeholder="Bild aus Medienbibliothek wählen oder URL eingeben">
                <button type="button" id="newsMediaSelect" class="uk-button uk-button-default uk-button-small uk-text-nowrap">
                  Aus Medienbibliothek
                </button>
                <label class="uk-button uk-button-default uk-button-small uk-text-nowrap" style="margin: 0;">
                  Hochladen
                  <input type="file" id="newsMediaUpload" accept="image/png,image/jpeg,image/webp,image/svg+xml" hidden>
                </label>
              </div>
              <div id="newsImagePreview" class="uk-margin-small-top" {% if not imageUrl %}style="display:none;"{% endif %}>
                <div class="uk-inline uk-width-1-1">
                  <img id="newsImagePreviewImg" src="{{ imageUrl|e }}" alt="Vorschau" style="max-height: 160px; max-width: 100%; border-radius: 4px; display: block;">
                  <button type="button" id="newsImageRemove" class="uk-position-top-right uk-button uk-button-danger uk-button-small" style="margin: 4px;" title="Bild entfernen">&times;</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# ── Actions ──────────────────────────────────────────── #}
      <div class="uk-width-1-1 uk-margin-top">
        <button type="submit" class="uk-button uk-button-primary">{{ t('button_save') }}</button>
        <a class="uk-button uk-button-default" href="{{ basePath }}/admin/landing-news{% if pageNamespace is not empty %}?namespace={{ pageNamespace|url_encode }}{% endif %}">{{ t('button_cancel') }}</a>
      </div>
      {% if error %}
        <div class="uk-width-1-1">
          <div class="uk-alert-danger" uk-alert>{{ error }}</div>
        </div>
      {% endif %}
    </form>

    {# ── Media picker modal ──────────────────────────────── #}
    <div id="newsMediaModal" class="uk-modal" uk-modal>
      <div class="uk-modal-dialog" style="width: 720px;">
        <button class="uk-modal-close-default" type="button" uk-close></button>
        <div class="uk-modal-header">
          <h2 class="uk-modal-title">Bild aus Medienbibliothek wählen</h2>
        </div>
        <div class="uk-modal-body">
          <div class="uk-margin-small-bottom uk-flex uk-flex-middle" style="gap: 0.5rem;">
            <input class="uk-input uk-flex-auto" type="search" placeholder="Suchen..." data-role="media-search">
            <select class="uk-select" style="width: auto;" data-role="media-scope">
              <option value="project">{{ pageNamespace ?: 'Projekt' }}</option>
              <option value="global">Global</option>
            </select>
          </div>
          <div class="uk-overflow-auto" style="max-height: 400px;">
            <div class="uk-grid-small uk-child-width-1-4@m uk-child-width-1-3 uk-text-center" uk-grid data-role="media-grid"></div>
          </div>
          <p class="uk-text-meta uk-text-center" data-role="media-empty" hidden>Keine Medien gefunden.</p>
          <p class="uk-text-center" data-role="media-loading" hidden>Lade Medien...</p>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block scripts %}
  <script src="{{ basePath }}/js/storage.js"></script>
  <script type="module" src="{{ basePath }}/js/admin-landing-news.js"></script>
{% endblock %}
