parameters:
  level: 4
  paths:
    - src
  bootstrapFiles:
    - phpstan-bootstrap.php
  ignoreErrors:
    - '#Call to function is_callable.+will always evaluate to true#'
    - '#Method App\\Service\\AwardService::join\(\) is unused#'
    -
      message: '#Property .+\:\:\$defaultNamespace is never read, only written#'
      paths:
        - src/Service/Mcp/
      reportUnmatched: false
    # Pre-existing: Stripe/subscription array shapes incomplete in PHPDoc
    -
      identifier: nullCoalesce.offset
      reportUnmatched: false
    -
      message: '#Strict comparison using [!=]== between .+ will always evaluate to (true|false)#'
      paths:
        - src/Routes/admin.php
        - src/Controller/Marketing/PageController.php
        - src/Service/NamespaceSubscriptionService.php
      reportUnmatched: false
    -
      message: '#Unreachable statement - code above always terminates#'
      path: src/Service/NamespaceSubscriptionService.php
      reportUnmatched: false
    -
      message: '#Access to an undefined property .+PageController::\$pdo#'
      path: src/Controller/Marketing/PageController.php
      reportUnmatched: false
    -
      message: '#Method App\\Service\\MarketingProxySyncService::getMainDomain\(\) is unused#'
      reportUnmatched: false
    -
      message: '#Call to function (method_exists|is_array)\(\) with Stripe\\.+ will always evaluate to (true|false)#'
      path: src/Service/StripeService.php
      reportUnmatched: false
